{
    "extends": "@shi-corp/development-utilities/config/typescript/base.json",
    "compilerOptions": {
        /* Emit */
        "outDir": "./bin", /* Specify an output folder for all emitted files. */
        "plugins": [
            {
                "transform": "typia/lib/transform"
            }
        ],
        "skipLibCheck": true,
        "strictNullChecks": true,
        "strict": true
    }
}
